generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TripMode {
  expense
  pool
}

model Trip {
  id            String           @id @default(cuid())
  title         String
  location      String?
  startDate     DateTime         @map("start_date")
  endDate       DateTime         @map("end_date")
  mode          TripMode
  createdByUserId String         @map("created_by_user_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  createdByUser User             @relation("TripCreator", fields: [createdByUserId], references: [id])
  memberships   TripMembership[]
  expenses      Expense[]
  contributions Contribution[]
  invitations   Invitation[]

  @@map("trip")
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  name          String
  emailVerified Boolean          @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at")
  tripsCreated  Trip[]           @relation("TripCreator")
  memberships   TripMembership[]
  invitations   Invitation[]
  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

model TripMembership {
  id            String         @id @default(cuid())
  tripId        String         @map("trip_id")
  userId        String         @map("user_id")
  createdAt     DateTime       @default(now()) @map("created_at")

  trip          Trip           @relation(fields: [tripId], references: [id])
  user          User           @relation(fields: [userId], references: [id])
  expenses      Expense[]
  splits        ExpenseSplit[]
  contributions Contribution[]

  @@unique([tripId, userId])
  @@map("trip_membership")
}

enum SplitType {
  equal_all
  equal_selected
  custom
}

model Expense {
  id                String          @id @default(cuid())
  tripId            String          @map("trip_id")
  title             String
  amount            Int
  date              DateTime
  splitType         SplitType       @map("split_type")
  payerMembershipId String?         @map("payer_membership_id")
  note              String?
  createdAt         DateTime        @default(now()) @map("created_at")

  trip              Trip            @relation(fields: [tripId], references: [id])
  payerMembership   TripMembership? @relation(fields: [payerMembershipId], references: [id])
  splits            ExpenseSplit[]

  @@map("expense")
}

model ExpenseSplit {
  id           String         @id @default(cuid())
  expenseId    String         @map("expense_id")
  membershipId String         @map("membership_id")
  amount       Int
  createdAt    DateTime       @default(now()) @map("created_at")

  expense      Expense        @relation(fields: [expenseId], references: [id])
  membership   TripMembership @relation(fields: [membershipId], references: [id])

  @@unique([expenseId, membershipId])
  @@map("expense_split")
}

model Contribution {
  id           String         @id @default(cuid())
  tripId       String         @map("trip_id")
  membershipId String         @map("membership_id")
  amount       Int
  date         DateTime
  createdAt    DateTime       @default(now()) @map("created_at")

  trip         Trip           @relation(fields: [tripId], references: [id])
  membership   TripMembership @relation(fields: [membershipId], references: [id])

  @@map("contribution")
}

enum InvitationRole {
  editor
}

model Invitation {
  id              String          @id @default(cuid())
  tripId          String          @map("trip_id")
  token           String          @unique
  role            InvitationRole  @default(editor)
  maxUses         Int?            @map("max_uses")
  usedCount       Int             @default(0) @map("used_count")
  expiresAt       DateTime?       @map("expires_at")
  acceptedAt      DateTime?       @map("accepted_at")
  revokedAt       DateTime?       @map("revoked_at")
  createdByUserId String?         @map("created_by_user_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  trip            Trip            @relation(fields: [tripId], references: [id])
  createdByUser   User?           @relation(fields: [createdByUserId], references: [id])

  @@map("invitation")
}
